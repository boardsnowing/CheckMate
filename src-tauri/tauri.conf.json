{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "check-mate",
  "version": "1.3.0",
  "identifier": "com.checkmate.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "check-mate",
        "width": 1280,
        "height": 960
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset: https://asset.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data: blob:",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/image",
          "$HOME/image/*",
          "$RESOURCE/test_data/**",
          "./test_data/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    }
  }
}